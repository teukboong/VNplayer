VNPLAYER_FRONTDOOR_URL=https://vnplayer-frontdoor.<your-subdomain>.workers.dev
VNPLAYER_FRONTDOOR_UPDATE_SECRET='${KEYCHAIN:vnplayer/frontdoor-origin-update-secret}'
VNPLAYER_CF_KV_NAMESPACE_ID=replace-with-workers-kv-namespace-id
VNPLAYER_TUNNEL=cloudflared
VNPLAYER_TUNNEL_TARGET_URL=http://127.0.0.1:4174
VNPLAYER_TUNNEL_HEALTH_CHECK=1
VNPLAYER_TUNNEL_HEALTH_INTERVAL_SEC=15
VNPLAYER_TUNNEL_HEALTH_FAILURE_LIMIT=3

# WebGPT browser seats. Keep text and CG separate, but both should point at
# logged-in Chrome profile roots.
VNPLAYER_WEBGPT_MCP_WRAPPER=./scripts/webgpt-local-wrapper.mjs
VNPLAYER_WEBGPT_TEXT_PROFILE_DIR=${HOME}/.vnplayer/chatgpt-text-profile
VNPLAYER_WEBGPT_TEXT_MANUAL_PROFILE_DIR=${HOME}/.vnplayer/chatgpt-text-profile
VNPLAYER_WEBGPT_TEXT_CDP_PORT=9228
VNPLAYER_WEBGPT_CG_PROFILE_DIR=${HOME}/.vnplayer/chatgpt-cg-profile
VNPLAYER_WEBGPT_CG_MANUAL_PROFILE_DIR=${HOME}/.vnplayer/chatgpt-cg-profile
VNPLAYER_WEBGPT_CG_CDP_PORT=9229
